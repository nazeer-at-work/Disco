{
  "name": "icon-pack-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "NODE_ENV=development bash ./scripts/run-android.sh",
    "android:dev": "NODE_ENV=development bash ./scripts/run-android.sh",
    "android:prod": "NODE_ENV=production bash ./scripts/run-android.sh",
    "build:icon-pack": "node scripts/generate-icon-pack.js --skip-appfilter && node scripts/generate-gallery-manifest.js",
    "build:appfilter": "node scripts/build-appfilter.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "setup": "node scripts/setup-pack.mjs",
    "release": "node scripts/release.mjs",
    "start": "NODE_ENV=development react-native start --port 19001 --reset-cache",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-vector-icons/material-icons": "^12.4.1",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.15.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native/babel-preset": "0.84.0",
    "@react-native/eslint-config": "0.84.0",
    "@react-native/metro-config": "0.84.0",
    "@react-native/typescript-config": "0.84.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.3",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
